{
  "name": "ec-dni-validator",
  "version": "1.0.0",
  "description": "A simple validator of Ecuadorian identity card numbers, also called \"cédulas\".",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "test": "jest --config jestconfig.json",
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "tslint -p tsconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint",
    "preversion": "npm run lint",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AngelAlexQC/ec-dni-validator.git"
  },
  "keywords": [
    "validator",
    "cedula",
    "dni",
    "ecuador",
    "ruc",
    "validador",
    "validar",
    "cédula"
  ],
  "author": "Ángel Quiroz",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AngelAlexQC/ec-dni-validator/issues"
  },
  "homepage": "https://github.com/AngelAlexQC/ec-dni-validator#readme",
  "devDependencies": {
    "@types/jest": "^27.0.2",
    "jest": "^27.2.4",
    "prettier": "^2.4.1",
    "ts-jest": "^27.0.5",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "^4.4.3"
  },
  "files": [
    "lib/**/*."
  ],
  "preferGlobal": true
}
